<?xml version="1.0" encoding="utf-8"?>
<!-- Modify this file to customize your launch splash screen -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@android:color/white" />

    <!-- Using a dedicated drawable image placed at
         android/app/src/main/res/drawable-nodpi/launch_image.png
         will make the same artwork available to the native splash. Copy your
         assets/images/jsba_logo.png to that path (see project assets). -->
    <item>
        <bitmap
            android:gravity="center"
            android:src="@drawable/launch_image" />
    </item>
</layer-list>
